{
  "name": "pi-maestro-teammate",
  "version": "0.4.5",
  "description": "Pi extension — teammate agent dispatch with DAG task graphs, RPC messaging, and compact TUI",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi",
    "teammate",
    "agents"
  ],
  "scripts": {
    "test": "node --experimental-transform-types --test \"test/*.test.ts\""
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./v1": "./src/public/v1/index.ts",
    "./v1/agents": "./src/public/v1/agents.ts",
    "./v1/child-extensions": "./src/public/v1/child-extensions.ts",
    "./v1/execution": "./src/public/v1/execution.ts",
    "./v1/extension": "./src/public/v1/extension.ts",
    "./v1/model-routing": "./src/public/v1/model-routing.ts",
    "./v1/prompts": "./src/public/v1/prompts.ts",
    "./v1/progress-tree": "./src/public/v1/progress-tree.ts",
    "./v1/types": "./src/public/v1/types.ts",
    "./src/*": "./src/*"
  },
  "deprecatedSubpaths": {
    "./src/*": "Compatibility only; use the versioned ./v1/* public API."
  },
  "files": [
    "src/**/*.ts",
    "agents/",
    "prompts/",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./src/extension/index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-agent-core": {
      "optional": true
    },
    "@earendil-works/pi-ai": {
      "optional": true
    },
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "@earendil-works/pi-tui": {
      "optional": true
    }
  },
  "dependencies": {
    "cross-spawn": "7.0.6",
    "typebox": "^1.1.24"
  },
  "devDependencies": {
    "@earendil-works/pi-agent-core": "0.80.3",
    "@earendil-works/pi-ai": "0.80.3",
    "@earendil-works/pi-coding-agent": "0.80.3",
    "@earendil-works/pi-tui": "0.80.3"
  },
  "directories": {
    "test": "test"
  },
  "author": "",
  "license": "ISC"
}
